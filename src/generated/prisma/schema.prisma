generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  url      = env("DATABASE_URL")
  provider = "sqlite"
}

enum LobsterKey {
  RED
  BLUE
  GOLD
}

enum DeliverySide {
  BUY
  SELL
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  PENDING
  FILLED
  CANCELLED
  REJECTED
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum CompetitionStatus {
  PENDING
  RUNNING
  PAUSED
  FINISHED
}

enum ParticipantStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  ELIMINATED
  QUIT
}

enum TradingSessionType {
  CALL_AUCTION_OPEN
  MORNING
  AFTERNOON
  CALL_AUCTION_CLOSE
  CLOSED
}

enum TradingSessionStatus {
  PENDING
  OPEN
  PAUSED
  CLOSED
}

enum OrderIntent {
  OPEN
  CLOSE
  SWITCH
}

enum RiskCheckStatus {
  PENDING
  PASSED
  REJECTED
}

model Agent {
  id          String      @id @default(cuid())
  name        String      @unique
  apiKey      String      @unique
  secretHash  String
  status      AgentStatus @default(ACTIVE)
  avatar      String?
  description String?
  model       String?
  market      String      @default("A")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  trades       Trade[]
  portfolios   Portfolio[]
  participants CompetitionParticipant[]
  orders       Order[]
  logs         LogEntry[]
  comments     Comment[]
  deliveries   Delivery[]

  @@index([apiKey])
}

model Competition {
  id                  String            @id @default(cuid())
  name                String
  description         String?
  status              CompetitionStatus @default(PENDING)
  startAt             DateTime?
  endAt               DateTime?
  initialCash         Float             @default(1000000)
  market              String            @default("A")
  testMode            Boolean           @default(false)
  mode                String            @default("REALTIME")
  entryRule           String            @default("INVITE_ONLY")
  tradableSymbolsJson String?
  maxPositionPct      Float             @default(1)
  maxHoldingSymbols   Int               @default(1)
  switchRequiresFlat  Boolean           @default(true)
  commissionRate      Float             @default(0)
  slippageBps         Int               @default(0)
  allowShort          Boolean           @default(false)
  scoreFormula        String?
  phase               String            @default("REGISTRATION")
  tradingCalendar     String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  participants    CompetitionParticipant[]
  portfolios      Portfolio[]
  orders          Order[]
  tradingSessions TradingSession[]
  snapshots       SettlementSnapshot[]
}

model Portfolio {
  id                 String   @id @default(cuid())
  agentId            String
  competitionId      String
  cash               Float    @default(1000000)
  totalValue         Float    @default(1000000)
  holdingSymbol      String?
  holdingCount       Int      @default(0)
  switchRequiresFlat Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  agent       Agent                   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  competition Competition             @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  participant CompetitionParticipant?
  positions   Position[]
  orders      Order[]
  settlements DailySettlement[]
  snapshots   SettlementSnapshot[]

  @@unique([agentId, competitionId])
  @@index([competitionId])
  @@index([holdingSymbol])
}

model Position {
  id           String   @id @default(cuid())
  portfolioId  String
  symbol       String
  quantity     Float
  avgCost      Float
  currentPrice Float?
  boughtAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol])
  @@index([portfolioId])
}

model Trade {
  id            String      @id @default(cuid())
  agentId       String
  symbol        String
  side          TradeSide
  quantity      Float
  price         Float
  status        TradeStatus @default(PENDING)
  filledAt      DateTime?
  executedPrice Float?
  note          String?
  commission    Float?
  stampTax      Float?
  transferFee   Float?
  netAmount     Float?
  createdAt     DateTime    @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([symbol, createdAt])
}

model Price {
  id        String   @id @default(cuid())
  symbol    String   @unique
  name      String?
  price     Float
  prevClose Float
  updatedAt DateTime @updatedAt

  @@index([symbol])
}

model Lobster {
  id          String     @id @default(cuid())
  key         LobsterKey @unique
  name        String
  description String?
  color       String?
  isActive    Boolean    @default(false)
  agentId     String?    @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  deliveries Delivery[]
  comments   Comment[]
  logs       LogEntry[]
}

model Delivery {
  id          String       @id @default(cuid())
  agentId     String
  lobsterId   String?
  symbol      String
  side        DeliverySide
  quantity    Float
  price       Float
  deliveredAt DateTime
  note        String?
  createdAt   DateTime     @default(now())

  agent   Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lobster Lobster? @relation(fields: [lobsterId], references: [id], onDelete: Cascade)

  @@index([agentId, deliveredAt])
  @@index([lobsterId, deliveredAt])
}

model Comment {
  id        String   @id @default(cuid())
  author    String
  content   String
  sentiment Int?
  lobsterId String?
  agentId   String?
  createdAt DateTime @default(now())

  lobster Lobster? @relation(fields: [lobsterId], references: [id], onDelete: Cascade)
  agent   Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([lobsterId, createdAt])
  @@index([agentId, createdAt])
}

model LogEntry {
  id        String   @id @default(cuid())
  title     String
  content   String
  level     String   @default("INFO")
  lobsterId String?
  agentId   String?
  createdAt DateTime @default(now())

  lobster Lobster? @relation(fields: [lobsterId], references: [id], onDelete: Cascade)
  agent   Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([lobsterId, createdAt])
  @@index([agentId, createdAt])
}

model Order {
  id               String          @id @default(cuid())
  agentId          String
  competitionId    String
  portfolioId      String
  participantId    String?
  tradingSessionId String?
  symbol           String
  side             TradeSide
  quantity         Float
  note             String?
  status           String          @default("PENDING")
  intent           OrderIntent     @default(OPEN)
  riskCheckStatus  RiskCheckStatus @default(PENDING)
  riskRejectCode   String?
  rejectReason     String?
  submittedAt      DateTime        @default(now())
  matchedAt        DateTime?

  agent          Agent                   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  competition    Competition             @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  portfolio      Portfolio               @relation(fields: [portfolioId], references: [id])
  participant    CompetitionParticipant? @relation(fields: [participantId], references: [id])
  tradingSession TradingSession?         @relation(fields: [tradingSessionId], references: [id])

  @@index([agentId, submittedAt])
  @@index([competitionId, status])
  @@index([portfolioId])
  @@index([participantId])
  @@index([tradingSessionId])
}

model DailySettlement {
  id           String   @id @default(cuid())
  portfolioId  String
  date         String
  cash         Float
  positionJson String?
  positionDays Int      @default(0)
  totalValue   Float
  returnPct    Float
  createdAt    DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, date])
  @@index([portfolioId])
}

model CompetitionParticipant {
  id               String            @id @default(cuid())
  competitionId    String
  agentId          String
  portfolioId      String?           @unique
  status           ParticipantStatus @default(PENDING)
  displayName      String?
  tagline          String?
  strategyTagsJson String?
  riskLevel        String?
  webhookUrl       String?
  apiVersion       String?
  joinedAt         DateTime          @default(now())
  approvedAt       DateTime?
  eliminatedAt     DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  competition Competition          @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  agent       Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  portfolio   Portfolio?           @relation(fields: [portfolioId], references: [id])
  orders      Order[]
  snapshots   SettlementSnapshot[]

  @@unique([competitionId, agentId])
  @@index([competitionId, status])
  @@index([agentId, status])
}

model TradingSession {
  id                      String               @id @default(cuid())
  competitionId           String
  tradingDate             String
  sessionType             TradingSessionType
  status                  TradingSessionStatus @default(PENDING)
  openAt                  DateTime
  closeAt                 DateTime
  marketSnapshotJson      String?
  leaderboardSnapshotJson String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  competition Competition          @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  orders      Order[]
  snapshots   SettlementSnapshot[]

  @@unique([competitionId, tradingDate, sessionType])
  @@index([competitionId, tradingDate])
  @@index([competitionId, status])
}

model SettlementSnapshot {
  id               String   @id @default(cuid())
  competitionId    String
  tradingSessionId String?
  participantId    String?
  portfolioId      String
  snapshotAt       DateTime @default(now())
  cash             Float
  marketValue      Float
  totalValue       Float
  realizedPnL      Float    @default(0)
  unrealizedPnL    Float    @default(0)
  returnPct        Float
  drawdownPct      Float    @default(0)
  turnoverPct      Float    @default(0)
  rank             Int?
  holdingSymbol    String?
  positionJson     String?
  metricsJson      String?
  createdAt        DateTime @default(now())

  competition    Competition             @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  tradingSession TradingSession?         @relation(fields: [tradingSessionId], references: [id])
  participant    CompetitionParticipant? @relation(fields: [participantId], references: [id])
  portfolio      Portfolio               @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([competitionId, snapshotAt])
  @@index([portfolioId, snapshotAt])
  @@index([participantId, snapshotAt])
}
